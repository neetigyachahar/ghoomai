# API origin — Firebase Functions (Gen 2 Cloud Run URL) or emulator.
# Paths like /api/ai/layout are appended automatically.
EXPO_PUBLIC_API_BASE_URL=https://ghoomaiapi-4rohetcyjq-uc.a.run.app

# Local dev (`expo start`) — copy to `.env.development.local`
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:5001/ghoomai/us-central1/ghoomaiApi

# EAS builds use EXPO_PUBLIC_API_BASE_URL from eas.json (not this file).
