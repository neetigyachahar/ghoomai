# Production API URL — baked into static export by `next build` / Firebase deploy.
# Copy to `.env.production` before deploying hosting.
NEXT_PUBLIC_API_BASE_URL=https://ghoomaiapi-4rohetcyjq-uc.a.run.app

# Local dev (`next dev`) — copy to `.env.development.local` (NOT `.env.local`).
# `.env.local` is loaded during production builds and overrides `.env.production`.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5001/ghoomai/us-central1/ghoomaiApi
