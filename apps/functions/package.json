{
  "name": "functions",
  "version": "0.0.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=lib/index.js --external:firebase-admin --external:firebase-functions --external:express --external:cors",
    "dev": "bun run build && firebase emulators:start --only functions",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "prepare-deploy": "node scripts/prepare-deploy.mjs",
    "restore-deploy": "node scripts/restore-deploy.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2"
  },
  "devDependencies": {
    "@repo/api": "*",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
